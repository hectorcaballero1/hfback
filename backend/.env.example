# Serverless Framework v4 - nombre de tu org en app.serverless.com
SLS_ORG=mi-org

# AWS Academy - refrescar desde AWS Details cada sesión
ACCOUNT_ID=123456789012

# Groq API (LLM primario) - https://console.groq.com
GROQ_API_KEY=gsk_...

# Gemini API (fallback opcional)
GEMINI_API_KEY=

# Resend (notificación por correo de respuestas RAG / acuses de enrutado) - https://resend.com
# Sandbox: sin dominio propio, solo envía a tu correo de la cuenta Resend; el resto lo rechaza (inofensivo).
RESEND_API_KEY=
# Opcional: remitente. Sin dominio verificado debe ser onboarding@resend.dev (default si se deja vacío).
EMAIL_FROM=

# URL del servicio RAG en la EC2 (sin slash final)
# Dejar vacío si el RAG no está listo (el worker usará fallback a enrutado)
RAG_URL=http://IP_EC2:8000
